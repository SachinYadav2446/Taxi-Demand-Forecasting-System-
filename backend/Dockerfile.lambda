FROM public.ecr.aws/lambda/python:3.11

# Install build tools for scientific packages
RUN yum install -y gcc-c++ pkgconfig python3-devel

# Copy function code
COPY . ${LAMBDA_TASK_ROOT}

# Install dependencies with verbose output to identify failures
RUN pip install --no-cache-dir -r requirements.txt -v

# Set the CMD to your handler (filename.method)
CMD [ "main.handler" ]
